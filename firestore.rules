rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Is the signed-in user a CMS/admin-panel staff member?
    // Reads the isStaff boolean field from the unified users/{uid} doc.
    // (Role-specific gating — e.g. admin vs manager vs gamer — happens
    // client-side in app/lib/adminAuth.ts; this only checks "is staff at all".)
    function isStaff() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isStaff', false) == true;
    }

    // ---- Public storefront content, staff-managed ----
    match /games/{id}          { allow read: if true; allow write: if isStaff(); }
    match /gameCategories/{id} { allow read: if true; allow write: if isStaff(); }
    match /menuCategories/{id} { allow read: if true; allow write: if isStaff(); }
    match /menuItems/{id}      { allow read: if true; allow write: if isStaff(); }
    match /events/{id}         { allow read: if true; allow write: if isStaff(); }
    match /eventTypes/{id}     { allow read: if true; allow write: if isStaff(); }
    match /dndCampaigns/{id}   { allow read: if true; allow write: if isStaff(); }
    match /levelPerks/{id}     { allow read: if true; allow write: if isStaff(); }

    // ---- Staff-only ----
    match /activityLog/{id}  { allow read, write: if isStaff(); }

    // Per-user status notifications — reservation approvals/rejections written
    // by staff, read+dismissed by the recipient only.
    match /notifications/{id} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if isStaff();
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }
    match /mediaLibrary/{id} { allow read, write: if isStaff(); }

    // Staff directory. Anyone signed in may read (the app needs to look up
    // its own role on every load). Only existing staff may write — rules
    // have no way to check "is this collection empty," only "does this one
    // document exist," so there's no safe way to auto-elect a first admin
    // here. Provision the first admin by hand instead: Firebase Console →
    // Firestore → create one `adminUsers/{uid}` document with
    // `role: "admin"`, using the uid from Authentication → Users after that
    // person signs in once. See ARCHITECTURE.md for more detail.
    // Transient gate for staff-account creation. The admin writes an invitation
    // here (isStaff() reads users, writes adminInvitations — different ✓),
    // then the new staff member creates their own users/{uid} doc using their
    // own token, with the invitation as proof of admin intent (reads
    // adminInvitations, writes users — different ✓). Deleted immediately after.
    match /adminInvitations/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isStaff();
    }

    // ---- Customer accounts ----
    // A customer may freely edit their own profile fields (avatar, theme,
    // username, the level/levelTitle display cache), but xp/obCoins must
    // stay unchanged in a customer-initiated update — the only legitimate
    // way to change a balance is a staff-approved transaction or redemption
    // (see approveTransaction in app/lib/loyalty.ts and confirmRedemption in
    // app/lib/redemptions.ts). On creation, a customer may only set
    // xp/obCoins to 0, matching the initial value ensureCustomerDoc always
    // writes (app/lib/customerAuth.ts).
    //
    // This top-level doc is readable by any signed-in customer (friend
    // search and the leaderboard both read other customers' profiles), so
    // anything that shouldn't be that widely exposed lives in one of the
    // two private sub-docs below instead — split into two, not one,
    // because they need different read access: a customer can read back
    // their own avatarDeleteUrl (the profile page's own avatar-cleanup
    // flow needs it), but a phone number is admin-lookup-only — not even
    // the customer who gave it can read it back through this doc.
    //
    // isBoundedString caps a free-text field's length on customer-initiated
    // writes (not staff writes — staff are trusted, same as the xp/obCoins
    // checks above) without requiring the field to be present at all, so
    // accounts that predate a given field (e.g. firstName/lastName, added
    // after this app already had customers) can still update *other*
    // fields on their own doc without being blocked by a field they were
    // never asked to set.
    function isBoundedString(data, field, maxLen) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxLen);
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        // Regular customer self-signup: no staff tag, loyalty balances start at 0.
        (request.auth.uid == userId &&
          request.resource.data.xp == 0 &&
          request.resource.data.obCoins == 0 &&
          request.resource.data.get('isStaff', false) != true) ||
        // Staff account creation — new user creates their own doc using their
        // own token, gated by an admin-written invitation (different collection).
        // This avoids calling isStaff() on the same collection being written.
        (request.auth.uid == userId &&
          exists(/databases/$(database)/documents/adminInvitations/$(userId)))
      );
      allow update: if request.auth != null && (
        isStaff() ||
        (request.auth.uid == userId &&
          request.resource.data.xp == resource.data.xp &&
          request.resource.data.obCoins == resource.data.obCoins &&
          request.resource.data.get('isStaff', false) == resource.data.get('isStaff', false))
      );
      allow delete: if isStaff();

      // avatarDeleteUrl: the customer needs to read this back themselves
      // (profile page's own avatar-replacement cleanup, and the
      // /api/media/delete route reading it server-side as the calling
      // customer) — see app/(customer)/customer/profile/page.tsx and
      // app/lib/serverAuth.ts.
      match /private/avatar {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isStaff());
      }

      // contact: phone number + real first/last name, staff-lookup only —
      // the main users/{uid} doc above is broadly readable by any
      // signed-in customer (friend search, leaderboard), so nothing here
      // belongs there. Write access stays with the owner (they're the one
      // providing it at signup), but nobody, including the customer
      // themselves, can read it back through here except staff.
      match /private/contact {
        allow read: if isStaff();
        allow write: if isStaff() ||
          (request.auth != null && request.auth.uid == userId &&
            isBoundedString(request.resource.data, 'firstName', 50) &&
            isBoundedString(request.resource.data, 'lastName', 50));
      }
    }
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // xpAmount/coinsAmount are bounds-checked on creation rather than
    // trusted as-is — a customer submitting their own check is the only
    // transaction type created directly by a customer (event/D&D attendance
    // is logged by staff), so the caps are generous-but-bounded upper
    // limits, not exact expected values. Customer self-submissions also
    // require a verified email; staff-logged attendance is exempted since
    // it isn't self-reported.
    match /transactions/{id} {
      allow read: if request.auth != null && (
        resource.data.status == 'approved' ||
        request.auth.uid in resource.data.userId ||
        isStaff()
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.submittedBy &&
        request.resource.data.status == 'pending' &&
        (isStaff() || request.auth.token.email_verified == true) &&
        request.resource.data.xpAmount is int &&
        request.resource.data.xpAmount >= 0 && request.resource.data.xpAmount <= 10000 &&
        request.resource.data.coinsAmount is int &&
        request.resource.data.coinsAmount >= 0 && request.resource.data.coinsAmount <= 2000;
      // Staff can update any field (approve/reject). The original submitter
      // may also cancel their own still-pending submission — not every
      // person tagged in a split, just whoever created it — and that's the
      // only transition they get: pending -> cancelled, nothing else.
      allow update: if isStaff() ||
        (request.auth != null &&
          request.auth.uid == resource.data.submittedBy &&
          resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status == 'cancelled');
    }
    match /transactionLog/{id} {
      allow read, write: if isStaff();
    }

    match /friendRequests/{id} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.fromUid &&
        request.resource.data.status == 'pending';
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.toUid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'accepted';
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid
      );
    }

    // Mobile-app loyalty rewards catalog — admin creates rewards,
    // customers browse to see what coins can be redeemed for.
    match /rewards/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Public, like games/menuItems/events above — the Loyalty page shows
    // what's redeemable to everyone, signed in or not, as part of the
    // pitch for why someone should join the program in the first place.
    match /redemptionItems/{itemId} {
      allow read: if true;
      allow write: if isStaff();
    }
    // Every redemption request is customer-initiated (staff only approve —
    // see allow update), so the verified-email requirement applies
    // unconditionally here, unlike transactions' isStaff() exemption above.
    // coinCost is pinned to redemptionItems' own current price rather than
    // trusted from the request — otherwise a customer could request a
    // pricey item while claiming whatever low coinCost they like, and
    // confirmRedemption (app/lib/redemptions.ts) deducts exactly what's
    // stored on the redemption, not the item's real price.
    match /redemptions/{redemptionId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isStaff());
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.requestedBy &&
        request.auth.token.email_verified == true &&
        request.resource.data.status == 'pending' &&
        request.resource.data.coinCost ==
          get(/databases/$(database)/documents/redemptionItems/$(request.resource.data.itemId)).data.coinCost;
      // Staff can update any field (confirm/reject). The requester may also
      // cancel their own still-pending request — pending -> cancelled only.
      allow update: if isStaff() ||
        (request.auth != null &&
          request.auth.uid == resource.data.requestedBy &&
          resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status == 'cancelled');
    }

    // Update is the invitee responding — acceptInvite()/declineInvite() in
    // app/lib/participantInvites.ts only ever flip status pending -> accepted
    // or declined, so that's all this rule allows too; nothing lets the
    // invitee rewrite reservationId, inviterUid, or any other field on a
    // doc they don't own the content of.
    match /participantInvites/{id} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.inviteeUid || request.auth.uid == resource.data.inviterUid || isStaff());
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.inviterUid &&
        request.resource.data.status == 'pending';
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.inviteeUid &&
        resource.data.status == 'pending' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['accepted', 'declined'];
    }

    // Update is allowed for staff (approving/rejecting, any field), or for
    // any signed-in user but *only* to drop exactly one entry from
    // `participants` — the shape of declineInvite's update in
    // app/lib/participantInvites.ts. This is deliberately narrow: it
    // doesn't (and can't, with rules alone) confirm the removed entry was
    // the requester's own, but it does stop a non-staff update from
    // touching `dmUid`, `startAt`, `status`, or any other field on
    // somebody else's reservation.
    match /dndReservations/{id} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isStaff());
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.requestedBy &&
        request.resource.data.status == 'pending';
      allow update: if isStaff() ||
        (request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']) &&
          request.resource.data.participants.size() == resource.data.participants.size() - 1) ||
        // Customer cancellation: pending or approved → cancelled only.
        (request.auth != null &&
          request.auth.uid == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']) &&
          request.resource.data.status == 'cancelled' &&
          resource.data.status in ['pending', 'approved']);
    }
    // Same as dndReservations above, except declining also decrements the
    // separate `partySize` counter (D&D has no such field — its party size
    // is computed on the fly from `participants`).
    match /eventReservations/{id} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isStaff());
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.requestedBy &&
        request.resource.data.status == 'pending';
      allow update: if isStaff() ||
        (request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'partySize']) &&
          request.resource.data.participants.size() == resource.data.participants.size() - 1 &&
          request.resource.data.partySize == resource.data.partySize - 1) ||
        // Customer cancellation: pending or approved → cancelled only.
        (request.auth != null &&
          request.auth.uid == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']) &&
          request.resource.data.status == 'cancelled' &&
          resource.data.status in ['pending', 'approved']);
    }
    // A lock only blocks a DM's calendar if it's backed by a real,
    // already-created reservation owned by the same person creating the
    // lock, for the same DM, within that reservation's own booked time
    // range — otherwise any signed-in customer could read a DM's public
    // dmUid off /dnd and lock out their entire calendar with no
    // reservation behind it at all (nothing else ever cleans up a lock
    // that isn't tied to a real reservation's reject flow).
    function lockReservation(resId) {
      return get(/databases/$(database)/documents/dndReservations/$(resId)).data;
    }
    match /dndDmLocks/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.reservationId is string &&
        request.resource.data.bucketStart is timestamp &&
        lockReservation(request.resource.data.reservationId).requestedBy == request.auth.uid &&
        lockReservation(request.resource.data.reservationId).dmUid == request.resource.data.dmUid &&
        request.resource.data.bucketStart >= lockReservation(request.resource.data.reservationId).startAt &&
        request.resource.data.bucketStart < lockReservation(request.resource.data.reservationId).blockedUntil;
      allow delete: if isStaff();
    }

    // ---- D&D Looking-for-Players matchmaking ----
    // A customer expresses interest in a campaign (no date/time involved
    // at all — that's dndReservations, a separate concept), and staff
    // assemble interested customers into groups. Deterministic doc id
    // (campaignId_userId) means a customer can only ever have one entry
    // per campaign, so rules can reject a duplicate signup without a query.
    match /lfpEntries/{entryId} {
      // The third branch lets a forming party's own leader read every
      // entry pointing at their group (maybeFinalizeParty in
      // app/lib/dndGroups.ts needs every member's entry, not just their
      // own, to assemble the final roster) — groupId is null for anyone
      // still solo-waiting, so this only ever applies to grouped entries.
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isStaff() ||
          (resource.data.groupId != null &&
            get(/databases/$(database)/documents/dndGroups/$(resource.data.groupId)).data.formedBy == request.auth.uid));
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId &&
        entryId == (request.resource.data.campaignId + '_' + request.resource.data.userId) &&
        (
          // Solo join — staff sort these into a group later.
          (request.resource.data.status == 'waiting' && request.resource.data.groupId == null) ||
          // Joining a real group directly — either starting it as its own
          // leader (startLfpParty), or accepting a friend's invite
          // (acceptInvite's 'lfp' branch in app/lib/participantInvites.ts).
          // Checking the group merely *exists* isn't enough on its own —
          // group ids are visible to anyone who can read that group (e.g.
          // a groupmate), so without this, any signed-in customer could
          // self-write their way into someone else's party. The invite
          // doc's id is deterministic (groupId_inviteeUid, set by
          // startLfpParty) specifically so this can look it up directly —
          // rules can't run a query to find "is there an invite for me".
          (request.resource.data.status == 'grouped' &&
            (
              get(/databases/$(database)/documents/dndGroups/$(request.resource.data.groupId)).data.formedBy == request.auth.uid ||
              exists(/databases/$(database)/documents/participantInvites/$(request.resource.data.groupId + '_' + request.auth.uid))
            ))
        );
      // Only staff move someone between waiting/grouped or assign a
      // groupId — see addToGroup/removeFromGroup/transferToGroup in
      // app/lib/dndGroups.ts, which update this in the same batch as the
      // matching dndGroups doc.
      allow update: if isStaff();
      // A customer may delete their own entry at any status — solo-waiting
      // (cancel the queue), or grouped (leave the group). The companion
      // dndGroups update (removing them from memberUids/members) is handled
      // by the dndGroups self-removal rule below; both writes go in one
      // batch so the two docs can't drift out of sync.
      allow delete: if isStaff() ||
        (request.auth != null && request.auth.uid == resource.data.userId);
    }
    // memberUids is a plain string array (not the richer {uid,name}
    // `members` list) specifically so rules can check membership directly
    // — rules can't map() over a list of maps to pull out just the uid
    // field for comparison.
    //
    // Two ways a group exists: staff assemble one from the waiting pool
    // (isStaff(), unrestricted), or a customer starts one as its own
    // leader (formedBy == their uid) — see startLfpParty in
    // app/lib/dndGroups.ts. A leader-started group begins 'forming' with
    // only themselves confirmed; their own client flips it to 'confirmed'
    // once every invite they sent has been accepted or declined — still
    // just the leader updating a group they own, not a new permission tier.
    match /dndGroups/{id} {
      allow read: if request.auth != null &&
        (isStaff() || request.auth.uid in resource.data.memberUids || request.auth.uid == resource.data.formedBy);
      allow create: if isStaff() ||
        (request.auth != null &&
          request.resource.data.formedBy == request.auth.uid &&
          request.resource.data.status == 'forming' &&
          request.resource.data.memberUids == [request.auth.uid]);
      allow update: if isStaff() ||
        // Group leader updating their own forming party (e.g. maybeFinalizeParty
        // flipping status to 'confirmed').
        (request.auth != null &&
          request.auth.uid == resource.data.formedBy &&
          request.resource.data.formedBy == resource.data.formedBy &&
          request.resource.data.campaignId == resource.data.campaignId) ||
        // Any member removing only themselves from memberUids/members — the
        // companion lfpEntries delete goes in the same batch (leaveGroupAsMember
        // in app/lib/dndGroups.ts). Only memberUids, members, and updatedAt
        // may change; the caller must go from present to absent in memberUids.
        (request.auth != null &&
          resource.data.memberUids.hasAny([request.auth.uid]) &&
          !request.resource.data.memberUids.hasAny([request.auth.uid]) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members', 'updatedAt']));
      allow delete: if isStaff() ||
        (request.auth != null && request.auth.uid == resource.data.formedBy && resource.data.status == 'forming');
    }

    // ---- Table reservations (per-branch floor-plan booking) ----
    // One layout doc per branch, doc id == the branch name itself — public
    // read (customers need to see the map to book, signed in or not),
    // staff-only write (the admin table map editor).
    match /branchTableLayouts/{branch} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Same shape as dndReservations/eventReservations — instant lock,
    // 'pending' until staff approve/reject. tableIds/partySize are
    // bounds-checked on create the same way transactions' xpAmount/
    // coinsAmount are: a generous sanity backstop, not the real capacity
    // check (that's enforced client-side against the actual table(s)
    // picked, same posture as eventReservations' min/max).
    match /tableReservations/{id} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isStaff());
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.requestedBy &&
        request.resource.data.status == 'pending' &&
        request.resource.data.tableIds is list &&
        request.resource.data.partySize is int &&
        request.resource.data.partySize >= 1 && request.resource.data.partySize <= 50;
      // Staff may update any field. The customer who submitted may cancel
      // their own reservation (pending or approved → cancelled only),
      // changing only status and cancelledAt.
      allow update: if isStaff() ||
        (request.auth != null &&
          request.auth.uid == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']) &&
          request.resource.data.status == 'cancelled' &&
          resource.data.status in ['pending', 'approved']);
    }

    // Generalizes dndDmLocks' deterministic-doc-per-bucket pattern from one
    // locked resource (a DM) to every table in a joint booking. Ownership
    // is validated from the lock doc's own requestedBy field (denormalized
    // there at write time — see createTableReservationRequest), not via a
    // get() back to the sibling tableReservations doc created in the same
    // transaction — rules-triggered get() calls aren't guaranteed to see a
    // sibling write from earlier in the same commit (unlike the client's
    // own tx.get() calls, which are), so this avoids depending on that.
    match /tableLocks/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.tableId is string &&
        request.resource.data.reservationId is string &&
        request.resource.data.bucketStart is timestamp &&
        request.resource.data.requestedBy == request.auth.uid;
      allow delete: if isStaff();
    }

    // Staff-only purchase orders — customers never touch this collection.
    // Write covers create (record a sale) and update (attach invoiceUrl after
    // the upload, or flip status to 'refunded') — both operations go through
    // gamePurchases.ts helpers and are always staff-initiated.
    match /gamePurchaseOrders/{id} {
      allow read, write: if isStaff();
    }

    match /appSettings/{id} {
      allow read, write: if isStaff();
    }

    // Everything else is denied by default — Firestore rejects any
    // collection with no matching `match` block above, so this isn't
    // strictly required, but it's written out explicitly so that's never
    // ambiguous to a future reader of this file.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
